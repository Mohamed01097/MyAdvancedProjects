<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_executive_dashboard" model="ir.module.category">
        <field name="name">Executive Dashboard</field>
        <field name="sequence">37</field>
    </record>

    <record id="res_groups_privilege_executive_dashboard" model="res.groups.privilege">
        <field name="name">Executive Dashboard</field>
        <field name="sequence">37</field>
        <field name="category_id" ref="executive_dashboard.module_category_executive_dashboard"/>
    </record>

    <record id="group_dashboard_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="executive_dashboard.res_groups_privilege_executive_dashboard"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="rule_dashboard_report_log_own" model="ir.rule">
        <field name="name">Executive Dashboard Report Logs: Own Logs</field>
        <field name="model_id" ref="model_executive_dashboard_report_log"/>
        <field name="domain_force">[('generated_by', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_dashboard_report_log_manager" model="ir.rule">
        <field name="name">Executive Dashboard Report Logs: Managers</field>
        <field name="model_id" ref="model_executive_dashboard_report_log"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('executive_dashboard.group_dashboard_manager')), (4, ref('base.group_system'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_dashboard_alert_rule_user_company" model="ir.rule">
        <field name="name">Executive Dashboard Alert Rules: User Companies</field>
        <field name="model_id" ref="model_executive_dashboard_alert_rule"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_dashboard_alert_rule_manager_company" model="ir.rule">
        <field name="name">Executive Dashboard Alert Rules: Managers</field>
        <field name="model_id" ref="model_executive_dashboard_alert_rule"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('executive_dashboard.group_dashboard_manager')), (4, ref('base.group_system'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_dashboard_alert_history_user_read_company" model="ir.rule">
        <field name="name">Executive Dashboard Alert History: User Company Read</field>
        <field name="model_id" ref="model_executive_dashboard_alert_history"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_dashboard_alert_history_user_write_assigned" model="ir.rule">
        <field name="name">Executive Dashboard Alert History: Assigned User Write</field>
        <field name="model_id" ref="model_executive_dashboard_alert_history"/>
        <field name="domain_force">[('company_id', 'in', company_ids), ('responsible_user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="False"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_dashboard_alert_history_manager_company" model="ir.rule">
        <field name="name">Executive Dashboard Alert History: Managers</field>
        <field name="model_id" ref="model_executive_dashboard_alert_history"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('executive_dashboard.group_dashboard_manager')), (4, ref('base.group_system'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>
</odoo>
