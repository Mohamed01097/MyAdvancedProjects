<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Email template for scheduled dashboard reports -->
    <record id="email_report_scheduled" model="mail.template">
        <field name="name">Scheduled Dashboard Report</field>
        <field name="model_id" ref="model_executive_dashboard_report_schedule"/>
        <field name="subject">Dashboard Report: {{ object.dashboard_name }}</field>
        <field name="email_from">{{ object.user_id.email_formatted or user.email_formatted }}</field>
        <field name="body_html" type="html">
            <div style="font-family: Arial, sans-serif; line-height: 1.6; color: #333;">
                <p>Hello,</p>
                <p>Please find attached the scheduled <strong t-out="object.dashboard_name">Dashboard</strong> report.</p>
                <p><strong>Report Details:</strong></p>
                <ul>
                    <li><strong>Dashboard:</strong> <t t-out="object.dashboard_name"/></li>
                    <li><strong>Format:</strong> <t t-out="dict(object._fields['format'].selection).get(object.format)"/></li>
                    <li><strong>Frequency:</strong> <t t-out="dict(object._fields['frequency'].selection).get(object.frequency)"/></li>
                    <li><strong>Generated by:</strong> <t t-out="object.user_id.name"/></li>
                </ul>
                <p style="background-color: #f9f9f9; padding: 15px; border-radius: 4px; margin: 15px 0;">
                    This is an automated report. Please do not reply to this email.
                </p>
                <p>Best regards,<br/><strong>Odoo Executive Dashboard</strong></p>
            </div>
        </field>
    </record>
</odoo>
