<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Cron Job for Scheduled Reports -->
    <record id="cron_dashboard_scheduled_reports" model="ir.cron">
        <field name="name">Executive Dashboard: Generate Scheduled Reports</field>
        <field name="model_id" ref="model_executive_dashboard_report_schedule"/>
        <field name="state">code</field>
        <field name="code">model._run_scheduled_reports()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
