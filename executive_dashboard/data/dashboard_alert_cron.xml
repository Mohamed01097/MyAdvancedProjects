<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="cron_dashboard_alert_rule_evaluation" model="ir.cron">
        <field name="name">Executive Dashboard: Alert Rule Evaluation</field>
        <field name="model_id" ref="model_executive_dashboard_alert_rule"/>
        <field name="state">code</field>
        <field name="code">model._cron_evaluate_alert_rules()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
