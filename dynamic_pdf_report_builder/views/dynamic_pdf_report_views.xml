<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dynamic_pdf_report_list" model="ir.ui.view">
        <field name="name">dynamic.pdf.report.list</field>
        <field name="model">dynamic.pdf.report</field>
        <field name="arch" type="xml">
            <list string="Dynamic PDF Reports">
                <field name="name"/>
                <field name="model_id"/>
                <field name="report_title"/>
                <field name="state"/>
                <field name="report_action_id"/>
            </list>
        </field>
    </record>

    <record id="view_dynamic_pdf_report_form" model="ir.ui.view">
        <field name="name">dynamic.pdf.report.form</field>
        <field name="model">dynamic.pdf.report</field>
        <field name="arch" type="xml">
            <form string="Dynamic PDF Report">
                <header>
                    <button name="action_create_report" string="Create / Update Report" type="object" class="oe_highlight"/>
                    <button
                        name="action_preview_report"
                        string="Preview Report"
                        type="object"
                        invisible="not model_id or not field_line_ids"/>
                    <button
                        name="action_duplicate_design"
                        string="Duplicate Design"
                        type="object"
                        invisible="not id"/>
                    <button
                        name="action_export_template"
                        string="Export Template"
                        type="object"
                        groups="base.group_system"
                        invisible="not id"/>
                    <button name="action_apply_template" string="Apply Template" type="object"/>
                    <button name="action_reset_styling" string="Reset Styling" type="object"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Report name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="model_id"/>
                            <field name="model_name" readonly="1"/>
                            <field name="report_title"/>
                        </group>
                        <group>
                            <field name="state" readonly="1"/>
                            <field name="report_action_id" readonly="1"/>
                            <field name="last_generated_on" readonly="1"/>
                            <field name="last_generated_by" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Fields">
                            <field name="field_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field
                                        name="field_id"
                                        domain="[('model_id', '=', parent.model_id), ('ttype', 'in', ['char', 'text', 'html', 'integer', 'float', 'monetary', 'date', 'datetime', 'boolean', 'selection', 'many2one', 'many2many'])]"
                                    />
                                    <field name="field_description" readonly="1"/>
                                    <field name="field_type" readonly="1"/>
                                    <field name="field_name" readonly="1" optional="hide"/>
                                    <field name="show_label"/>
                                </list>
                            </field>
                        </page>
                        <page string="Line Sections">
                            <field name="line_section_ids" mode="list,form">
                                <list string="Line Sections" open_form_view="True">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field
                                        name="one2many_field_id"
                                        domain="[('model_id', '=', parent.model_id), ('ttype', '=', 'one2many')]"
                                    />
                                    <field name="related_model_name" readonly="1" optional="hide"/>
                                    <field name="show_section_title"/>
                                </list>
                                <form string="Line Section">
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="sequence"/>
                                                <field name="name"/>
                                                <field
                                                    name="one2many_field_id"
                                                    domain="[('model_id', '=', parent.model_id), ('ttype', '=', 'one2many')]"
                                                />
                                                <field name="one2many_field_name" readonly="1"/>
                                            </group>
                                            <group>
                                                <field name="related_model_id" readonly="1"/>
                                                <field name="related_model_name" readonly="1"/>
                                                <field name="show_section_title"/>
                                            </group>
                                        </group>
                                        <notebook>
                                            <page string="Fields">
                                                <field name="line_field_ids">
                                                    <list editable="bottom">
                                                        <field name="sequence" widget="handle"/>
                                                        <field
                                                            name="field_id"
                                                            domain="[('model_id', '=', parent.related_model_id), ('ttype', 'in', ['char', 'text', 'html', 'integer', 'float', 'monetary', 'date', 'datetime', 'boolean', 'selection', 'many2one', 'many2many'])]"
                                                        />
                                                        <field name="field_description" readonly="1"/>
                                                        <field name="field_type" readonly="1"/>
                                                        <field name="field_name" readonly="1" optional="hide"/>
                                                        <field name="show_label"/>
                                                    </list>
                                                </field>
                                            </page>
                                        </notebook>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Calculated Fields">
                            <field name="formula_ids" mode="list,form" context="{'active_test': False}">
                                <list string="Calculated Fields" editable="bottom" open_form_view="True">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="code" readonly="1" optional="show"/>
                                    <field name="scope"/>
                                    <field
                                        name="line_section_id"
                                        domain="[('report_id', '=', parent.id)]"
                                        invisible="scope != 'line_section'"
                                        required="scope == 'line_section'"/>
                                    <field name="formula_type"/>
                                    <field
                                        name="formula_expression"
                                        placeholder="amount_total * 0.15"
                                        invisible="formula_type not in ['arithmetic', 'concat']"
                                        required="formula_type in ['arithmetic', 'concat']"/>
                                    <field
                                        name="separator"
                                        invisible="formula_type != 'concat'"/>
                                    <field
                                        name="condition_expression"
                                        placeholder="amount_total &gt; 1000"
                                        invisible="formula_type != 'conditional'"
                                        required="formula_type == 'conditional'"/>
                                    <field
                                        name="true_value"
                                        invisible="formula_type != 'conditional'"/>
                                    <field
                                        name="false_value"
                                        invisible="formula_type != 'conditional'"/>
                                    <field name="output_label"/>
                                    <field name="active"/>
                                </list>
                                <form string="Calculated Field">
                                    <sheet>
                                        <group string="General">
                                            <group>
                                                <field name="sequence"/>
                                                <field name="name"/>
                                                <field name="code"/>
                                                <field name="active"/>
                                            </group>
                                            <group>
                                                <field name="scope"/>
                                                <field
                                                    name="line_section_id"
                                                    domain="[('report_id', '=', parent.id)]"
                                                    invisible="scope != 'line_section'"
                                                    required="scope == 'line_section'"/>
                                                <field name="formula_type"/>
                                            </group>
                                        </group>
                                        <group
                                            string="Arithmetic Formula"
                                            invisible="formula_type != 'arithmetic'">
                                            <field
                                                name="formula_expression"
                                                placeholder="amount_total * 0.15&#10;amount_untaxed + amount_tax&#10;product_uom_qty * price_unit"
                                                required="formula_type == 'arithmetic'"/>
                                        </group>
                                        <group
                                            string="Concat Formula"
                                            invisible="formula_type != 'concat'">
                                            <field
                                                name="formula_expression"
                                                placeholder="partner_id country_id"
                                                required="formula_type == 'concat'"/>
                                            <field
                                                name="separator"
                                                placeholder=" - "/>
                                        </group>
                                        <group
                                            string="Conditional Formula"
                                            invisible="formula_type != 'conditional'">
                                            <field
                                                name="condition_expression"
                                                placeholder="amount_total &gt; 1000"
                                                required="formula_type == 'conditional'"/>
                                            <field
                                                name="true_value"
                                                placeholder="VIP"/>
                                            <field
                                                name="false_value"
                                                placeholder="Normal"/>
                                        </group>
                                        <group string="Output">
                                            <group>
                                                <field name="output_label"/>
                                            </group>
                                            <group>
                                                <field name="show_in_report"/>
                                                <field name="show_in_line_tables"/>
                                            </group>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Grouping &amp; Totals">
                            <group string="Grouping">
                                <field name="group_ids" mode="list,form">
                                    <list string="Grouping Fields" editable="bottom" open_form_view="True">
                                        <field name="sequence" widget="handle"/>
                                        <field
                                            name="field_id"
                                            domain="[('model_id', '=', parent.model_id), ('ttype', 'in', ['char', 'selection', 'many2one', 'date', 'datetime', 'boolean'])]"
                                        />
                                        <field name="field_description" readonly="1"/>
                                        <field name="field_type" readonly="1"/>
                                        <field name="field_name" readonly="1" optional="hide"/>
                                    </list>
                                    <form string="Grouping Field">
                                        <sheet>
                                            <group>
                                                <group>
                                                    <field name="sequence"/>
                                                    <field
                                                        name="field_id"
                                                        domain="[('model_id', '=', parent.model_id), ('ttype', 'in', ['char', 'selection', 'many2one', 'date', 'datetime', 'boolean'])]"
                                                    />
                                                </group>
                                                <group>
                                                    <field name="field_description" readonly="1"/>
                                                    <field name="field_name" readonly="1"/>
                                                    <field name="field_type" readonly="1"/>
                                                </group>
                                            </group>
                                        </sheet>
                                    </form>
                                </field>
                            </group>
                            <group string="Totals">
                                <field name="aggregate_ids" mode="list,form">
                                    <list string="Aggregates" editable="bottom" open_form_view="True">
                                        <field
                                            name="field_id"
                                            domain="[('model_id', '=', parent.model_id), ('ttype', 'in', ['char', 'text', 'html', 'integer', 'float', 'monetary', 'date', 'datetime', 'boolean', 'selection', 'many2one', 'many2many'])]"
                                        />
                                        <field name="field_description" readonly="1"/>
                                        <field name="field_type" readonly="1"/>
                                        <field name="field_name" readonly="1" optional="hide"/>
                                        <field name="aggregate_type"/>
                                    </list>
                                    <form string="Aggregate">
                                        <sheet>
                                            <group>
                                                <group>
                                                    <field
                                                        name="field_id"
                                                        domain="[('model_id', '=', parent.model_id), ('ttype', 'in', ['char', 'text', 'html', 'integer', 'float', 'monetary', 'date', 'datetime', 'boolean', 'selection', 'many2one', 'many2many'])]"
                                                    />
                                                    <field name="aggregate_type"/>
                                                </group>
                                                <group>
                                                    <field name="field_description" readonly="1"/>
                                                    <field name="field_name" readonly="1"/>
                                                    <field name="field_type" readonly="1"/>
                                                </group>
                                            </group>
                                        </sheet>
                                    </form>
                                </field>
                            </group>
                        </page>
                        <page string="Visual Blocks">
                            <field name="block_ids" mode="list,form">
                                <list string="Visual Blocks" editable="bottom" open_form_view="True">
                                    <field name="sequence" widget="handle"/>
                                    <field name="block_type"/>
                                    <field name="title"/>
                                    <field name="position"/>
                                    <field name="alignment"/>
                                    <field name="is_active"/>
                                </list>
                                <form string="Visual Block">
                                    <sheet>
                                        <group>
                                            <group string="General">
                                                <field name="sequence"/>
                                                <field name="block_type"/>
                                                <field name="title"/>
                                                <field name="position"/>
                                                <field name="alignment"/>
                                                <field name="is_active"/>
                                            </group>
                                        </group>
                                        <group
                                            string="Content"
                                            invisible="block_type not in ['static_text', 'terms_conditions', 'note']">
                                            <field name="content" widget="html" nolabel="1"/>
                                        </group>
                                        <group
                                            string="QR / Barcode Settings"
                                            invisible="block_type not in ['qr_code', 'barcode']">
                                            <group>
                                                <field name="source_type"/>
                                                <field
                                                    name="source_field_id"
                                                    domain="[('model_id', '=', parent.model_id), ('ttype', 'in', ['char', 'text', 'integer', 'float', 'date', 'datetime', 'selection', 'many2one'])]"
                                                    invisible="source_type != 'field_value'"/>
                                                <field name="static_value" invisible="source_type != 'static_value'"/>
                                                <field name="custom_url_prefix" invisible="source_type != 'custom_url'"/>
                                            </group>
                                            <group>
                                                <field name="size"/>
                                            </group>
                                        </group>
                                        <group
                                            string="Signature Settings"
                                            invisible="block_type != 'signature'">
                                            <group>
                                                <field name="signature_label"/>
                                                <field name="show_signature_line"/>
                                            </group>
                                            <group>
                                                <field name="signer_name"/>
                                                <field name="signer_position"/>
                                            </group>
                                        </group>
                                        <group
                                            string="Watermark Settings"
                                            invisible="block_type != 'watermark'">
                                            <group>
                                                <field name="watermark_text"/>
                                                <field name="watermark_opacity"/>
                                            </group>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Layout &amp; Styling">
                            <group>
                                <group string="Layout">
                                    <field name="template_preset"/>
                                    <field name="layout_style"/>
                                    <field name="paper_size"/>
                                    <field name="direction"/>
                                    <field name="font_size"/>
                                    <field name="title_font_size"/>
                                </group>
                                <group string="Colors">
                                    <field name="primary_color" widget="color"/>
                                    <field name="secondary_color" widget="color"/>
                                    <field name="text_color" widget="color"/>
                                    <field name="table_header_bg_color" widget="color"/>
                                    <field name="table_header_text_color" widget="color"/>
                                    <field name="border_color" widget="color"/>
                                </group>
                            </group>
                            <group>
                                <group string="Header">
                                    <field name="show_company_logo"/>
                                    <field name="show_company_name"/>
                                    <field name="show_report_title"/>
                                </group>
                                <group string="Footer">
                                    <field name="show_footer"/>
                                    <field name="footer_text" invisible="not show_footer"/>
                                    <field name="show_print_date" invisible="not show_footer"/>
                                    <field name="show_page_number" invisible="not show_footer"/>
                                </group>
                            </group>
                            <group>
                                <group string="Table">
                                    <field name="table_border_style"/>
                                    <field name="zebra_rows"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_dynamic_pdf_report_search" model="ir.ui.view">
        <field name="name">dynamic.pdf.report.search</field>
        <field name="model">dynamic.pdf.report</field>
        <field name="arch" type="xml">
            <search string="Dynamic PDF Reports">
                <field name="name"/>
                <field name="model_id"/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="done" string="Done" domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter name="group_model" string="Model" context="{'group_by': 'model_id'}"/>
                <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="action_dynamic_pdf_report_builder" model="ir.actions.act_window">
        <field name="name">Dynamic PDF Report Builder</field>
        <field name="res_model">dynamic.pdf.report</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_dynamic_pdf_report_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create a dynamic PDF report</p>
            <p>Select a model, choose fields, then create the report action.</p>
        </field>
    </record>

    <menuitem
        id="menu_dynamic_pdf_report_builder"
        name="Dynamic PDF Report Builder"
        parent="base.menu_custom"
        action="action_dynamic_pdf_report_builder"
        sequence="95"
        groups="base.group_system"/>
</odoo>
