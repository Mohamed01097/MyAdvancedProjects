<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dynamic_pdf_report_library_list" model="ir.ui.view">
        <field name="name">dynamic.pdf.report.library.list</field>
        <field name="model">dynamic.pdf.report.library</field>
        <field name="arch" type="xml">
            <list string="Report Template Library">
                <field name="name"/>
                <field name="category"/>
                <field name="model_name" string="Model"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_dynamic_pdf_report_library_kanban" model="ir.ui.view">
        <field name="name">dynamic.pdf.report.library.kanban</field>
        <field name="model">dynamic.pdf.report.library</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="description"/>
                <field name="category"/>
                <field name="model_name"/>
                <field name="preview_image"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <t t-if="record.preview_image.raw_value">
                                    <img
                                        t-attf-src="/web/image/dynamic.pdf.report.library/#{record.id.raw_value}/preview_image"
                                        alt="Preview"/>
                                </t>
                                <t t-else="">
                                    <div class="d-flex align-items-center justify-content-center bg-100 text-muted h-100">
                                        <field name="category"/>
                                    </div>
                                </t>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="text-muted">
                                    <field name="model_name"/>
                                </div>
                                <div class="mt-1">
                                    <field name="description"/>
                                </div>
                                <div class="mt-2 d-flex gap-1 flex-wrap">
                                    <button
                                        name="action_install_template"
                                        type="object"
                                        class="btn btn-primary btn-sm"
                                        string="Install Template"/>
                                    <button
                                        name="action_preview_template"
                                        type="object"
                                        class="btn btn-secondary btn-sm"
                                        string="Preview Template"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_dynamic_pdf_report_library_form" model="ir.ui.view">
        <field name="name">dynamic.pdf.report.library.form</field>
        <field name="model">dynamic.pdf.report.library</field>
        <field name="arch" type="xml">
            <form string="Report Template Library">
                <header>
                    <button name="action_install_template" string="Install Template" type="object" class="oe_highlight"/>
                    <button name="action_preview_template" string="Preview Template" type="object"/>
                    <button name="action_create_custom_copy" string="Create Custom Copy" type="object"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Template name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="category"/>
                            <field name="model_name"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="preview_image" widget="image"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" nolabel="1" placeholder="Template description"/>
                    </group>
                    <notebook>
                        <page string="Configuration">
                            <field name="template_preview" readonly="1" nolabel="1"/>
                        </page>
                        <page string="JSON">
                            <field name="template_json" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_dynamic_pdf_report_library_preview_form" model="ir.ui.view">
        <field name="name">dynamic.pdf.report.library.preview.form</field>
        <field name="model">dynamic.pdf.report.library</field>
        <field name="arch" type="xml">
            <form string="Preview Template" create="0" edit="0" delete="0">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="category" readonly="1"/>
                            <field name="model_name" string="Model" readonly="1"/>
                        </group>
                        <group>
                            <field name="active" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" readonly="1" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Configuration">
                            <field name="template_preview" readonly="1" nolabel="1"/>
                        </page>
                        <page string="JSON">
                            <field name="template_json" readonly="1" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_install_template" string="Install Template" type="object" class="btn-primary"/>
                    <button name="action_create_custom_copy" string="Create Custom Copy" type="object" class="btn-secondary"/>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_dynamic_pdf_report_library_search" model="ir.ui.view">
        <field name="name">dynamic.pdf.report.library.search</field>
        <field name="model">dynamic.pdf.report.library</field>
        <field name="arch" type="xml">
            <search string="Report Template Library">
                <field name="name"/>
                <field name="code"/>
                <field name="model_name"/>
                <filter name="sales" string="Sales" domain="[('category', '=', 'sales')]"/>
                <filter name="accounting" string="Accounting" domain="[('category', '=', 'accounting')]"/>
                <filter name="purchase" string="Purchase" domain="[('category', '=', 'purchase')]"/>
                <filter name="inventory" string="Inventory" domain="[('category', '=', 'inventory')]"/>
                <filter name="hr" string="HR" domain="[('category', '=', 'hr')]"/>
                <filter name="generic" string="Generic" domain="[('category', '=', 'generic')]"/>
                <separator/>
                <filter name="group_category" string="Category" context="{'group_by': 'category'}"/>
                <filter name="group_model" string="Model" context="{'group_by': 'model_name'}"/>
            </search>
        </field>
    </record>

    <record id="action_dynamic_pdf_report_library" model="ir.actions.act_window">
        <field name="name">Template Library</field>
        <field name="res_model">dynamic.pdf.report.library</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_dynamic_pdf_report_library_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create a ready-made report template</p>
            <p>Library templates can be installed as editable dynamic PDF reports.</p>
        </field>
    </record>

    <menuitem
        id="menu_dynamic_pdf_report_template_library"
        name="Template Library"
        parent="menu_dynamic_pdf_report_builder"
        action="action_dynamic_pdf_report_library"
        sequence="20"
        groups="base.group_system"/>
</odoo>
